# --- Formula OS — variáveis de ambiente -------------------------------------
# Copie para `.env` (nunca comite o .env real).

# Servidor
HOST=0.0.0.0
PORT=4173
PUBLIC_BASE_URL=http://localhost:4173
COOKIE_SECURE=false
ALLOWED_ORIGINS=http://localhost:4173

# Persistência SQLite (vazio = caminho default no diretório do projeto)
SQLITE_PATH=

# Diretório de uploads de mídia (fotos/áudios do multiatendimento)
# Em produção Docker: /data/uploads  (mesmo volume do SQLite)
UPLOADS_DIR=

# Deploy (docker-compose + Caddy)
DOMAIN=portal.suaempresa.com
ACME_EMAIL=devops@suaempresa.com

# Supabase (projeto "Locks") — fonte de dados da vitrine pública
# A chave anon é pública por design; a RLS "read active vehicles" libera só a leitura.
SUPABASE_URL=https://SEU_PROJETO.supabase.co
SUPABASE_ANON_KEY=

# OpenRouter (SDR de IA)
# Pegue sua chave em https://openrouter.ai/keys
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-5-mini
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# WhatsApp — Meta Cloud API (provedor oficial)
# Documentação: https://developers.facebook.com/docs/whatsapp/cloud-api
META_VERIFY_TOKEN=mude-este-token-de-verificacao
META_APP_SECRET=

# WhatsApp — Evolution API (provedor não-oficial)
# https://doc.evolution-api.com/
EVOLUTION_BASE_URL=
EVOLUTION_API_KEY=
EVOLUTION_WEBHOOK_TOKEN=
