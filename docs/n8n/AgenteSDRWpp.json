      "parameters": {
        "operation": "executeQuery",
        "query": "select *\nfrom vehicles v\nwhere v.active\n  -- $1: brand (text ou null)\n  and (\n        coalesce(nullif(trim($1::text), ''), '_ALL_') = '_ALL_'\n        or v.brand ilike '%' || $1::text || '%'\n      )\n  -- $2: year_from (int ou null)\n  and v.fabrication_year BETWEEN ($2::int) and ($3::int)\n  -- $4: model (text ou null)\n  and (\n        coalesce(nullif(trim($4::text), ''), '_ALL_') = '_ALL_'\n        or v.model ilike '%' || $4::text || '%'\n      )\n  -- $5: category (text ou null)\n  and (\n        coalesce(nullif(trim($5::text), ''), '_ALL_') = '_ALL_'\n        or v.category ilike '%' || $5::text || '%'\n      )\n  -- $6: price_min and $7: price_max\n  and v.price BETWEEN ($6::int) and ($7::int)\norder by\n  v.price asc,\n  v.fabrication_year desc,\n  v.brand,\n  v.model;\n",
        "options": {
          "queryBatching": "single",
          "queryReplacement": "={{ $fromAI(\"brand\") || '_ALL_' }}, {{ $fromAI(\"year_from\") || 1949 }}, {{ $fromAI(\"year_to\") || $now.year }}, {{ $fromAI(\"model\") || '_ALL_' }}, {{ $fromAI(\"category\") || '_ALL_' }}, {{ $fromAI(\"price_min\") || 20000 }}, {{ $fromAI(\"price_max\") || 300000 }}"
        }
      },
