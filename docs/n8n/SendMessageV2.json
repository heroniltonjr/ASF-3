    {
      "parameters": {
        "operation": "executeQuery",
        "query": "INSERT INTO public.messages_sent (\n  store_name,\n  store_number,\n  store_focal,\n  store_lead_number,\n  message_sent\n)\nSELECT\n  s.store_name,\n  p.store_number,\n  s.store_focal,\n  p.store_lead_number,\n  p.message\nFROM public.stores s,\n     jsonb_to_record($1::jsonb) AS p(\n       store_number      text,\n       store_lead_number text,\n       message           text\n     )\nWHERE s.store_number = p.store_number\nRETURNING *;",
        "options": {
          "queryReplacement": "={{ JSON.stringify({\n  store_number: $('SendMessage').item.json.body.store_number,\n  store_lead_number: $json.total_leads, // se for o mesmo\n  message: $('SendMessage').item.json.body.message\n}) }}"
        }
