    {
      "parameters": {
        "operation": "executeQuery",
        "query": "UPDATE public.stores\nSET\n  total_leads      = COALESCE(total_leads, 0) + 1,\n  leads_this_month = COALESCE(leads_this_month, 0) + 1,\n  updated_at       = NOW()\nWHERE ctid = (\n    SELECT ctid\n    FROM public.stores\n    WHERE store_number = $1\n    ORDER BY \n      COALESCE(leads_this_month, 0) ASC, -- 1º critério: quem tem menos leads no mês\n      updated_at ASC                     -- 2º critério (desempate): quem foi atualizado há mais tempo\n    LIMIT 1\n)\nRETURNING\n  store_number,\n  total_leads,\n  leads_this_month,\n  updated_at;",
        "options": {
          "queryReplacement": "={{ $('SendMessage').item.json.body.store_number }}"
        }
      },
